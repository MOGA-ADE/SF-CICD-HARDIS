    <formulas>
        <name>formulaFournisseurToSet</name>
        <dataType>String</dataType>
        <expression>IF(
    ISBLANK({!varFournisseurOpportunity}),
    {!checkbox_fournisseur_choisis},
    IF(
        CONTAINS(&quot;;&quot; + SUBSTITUTE({!varFournisseurOpportunity}, &quot; &quot;, &quot;&quot;) + &quot;;&quot;, &quot;;&quot; + {!checkbox_fournisseur_choisis} + &quot;;&quot;),
        {!varFournisseurOpportunity},
        {!varFournisseurOpportunity} + &quot;;&quot; + {!checkbox_fournisseur_choisis}
    )
)</expression>
    </formulas>
