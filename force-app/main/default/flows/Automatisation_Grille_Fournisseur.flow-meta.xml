        <name>formula_marge_number_ekwateur</name>
        <dataType>Number</dataType>
        <expression>VALUE({!input_Marge_Ekwateur})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>formula_remaining_fournisseur</name>
        <dataType>String</dataType>
        <expression>MID( {!resteFournisseurs}, FIND(&quot;;&quot;, {!resteFournisseurs}) + 1, LEN({!resteFournisseurs}))</expression>
