    <formulas>
        <name>Formula_ExtrairePremier</name>
        <dataType>String</dataType>
        <expression>LEFT({!resteFournisseurs}, FIND(&quot;;&quot;, {!resteFournisseurs}) - 1)</expression>
    </formulas>
