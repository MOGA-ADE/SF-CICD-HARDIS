    <recordCreates>
        <name>CREATE_Quote_TURPE</name>
        <label>Create Quote TURPE</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignRecordIdToReference>varTQuoteId</assignRecordIdToReference>
        <connector>
            <targetReference>ASSIGN_Quote_Nouvellement_Creee</targetReference>
        </connector>
        <inputAssignments>
            <field>Date_de_fin_de_contrat__c</field>
            <value>
                <elementReference>$System.OriginDateTime</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>IsOptimisationTURPE__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Name</field>
            <value>
                <stringValue>Optimisation TURPE</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>OpportunityId</field>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Pricebook2Id</field>
            <value>
                <elementReference>GET_Pricebook2.Id</elementReference>
            </value>
        </inputAssignments>
        <object>Quote</object>
    </recordCreates>
    <recordDeletes>
        <name>DELETE_Empty_Quote</name>
        <label>Delete Empty Quote</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Copy_1_of_Cr_ation_des_QLI_Info</targetReference>
