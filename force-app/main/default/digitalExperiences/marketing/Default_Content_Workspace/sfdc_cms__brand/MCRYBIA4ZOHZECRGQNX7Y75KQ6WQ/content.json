          "casual" : {
            "label" : "Casual",
            "value" : "A conversational style that helps build closeness with the reader. The casual style uses intensifiers and exclamation points to express enthusiasm. It also uses words and phrases that are common in spoken language."
          },
          "inquisitive" : {
            "label" : "Inquisitive",
            "value" : "A style that poses open-ended questions relevant to the recipient’s interests or needs. The inquisitive style seeks to pique curiosity without being too complex. To foster engagement and a desire to learn more, this style ensures that the generated content provides an answer or solution to the question posed."
          },
          "plain" : {
            "label" : "Plain",
            "value" : "A style that uses brief, declarative sentences in an active voice with simple verb tenses (past, present, and future). The plain style favors short, everyday words and avoids jargon and long, potentially unfamiliar terms. This style is ideal for a wide range of readers regardless of expertise, and for readers who are in a hurry or aren’t native speakers of the language."
          },
          "professional" : {
            "label" : "Professional",
            "value" : "A formal style that gets straight to the point. The professional style uses intensifiers and adjectives sparingly, and asks questions only when necessary. This style avoids idioms and other unclear words and phrases."
          },
          "urgent" : {
            "label" : "Urgent",
            "value" : "A style that uses clear, concise language and time-sensitive words. The urgent style prioritizes deadlines or actions. To maintain trust and not appear aggressive, this style avoids overuse of capital letters and exclamation points."
          }
        }
      }
