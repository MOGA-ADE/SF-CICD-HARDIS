<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Motif_refus_manquant</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status, &quot;Refusée&quot;),
    ISBLANK(TEXT(Motif_refus__c))
)</errorConditionFormula>
    <errorDisplayField>Motif_refus__c</errorDisplayField>
    <errorMessage>Merci de renseigner un motif de refus</errorMessage>
</ValidationRule>
