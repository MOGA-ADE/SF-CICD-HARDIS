                    </div>

                    <table class="turpe-table">
                        <thead>
                            <tr>
                                <th rowspan="2" class="turpe-th-header-empty"></th>
                                <th rowspan="2" class="turpe-th-header">POSTES</th>
                                <th colspan="1" class="turpe-th-header">TURPE ACTUEL</th>
                                <th colspan="1" class="turpe-th-header">TURPE OPTIMAL</th>
                            </tr>
                            <tr>
                                <th class="turpe-th-sub">HTA CU</th>
                                <th class="turpe-th-sub">HTA LU</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="turpe-category" rowspan="5">DÉNIVELÉ DE<br/>PUISSANCE<br/>SOUSCRITE</td>
                                <td class="turpe-bold">HCE</td>
                                <td><apex:outputText value="{0,number,### ### ##0.00}"><apex:param value="{!lstQLITurpe[0].HCEActuel__c}" /></apex:outputText></td>
                                <td><img src="{!URLFOR($Resource.BlurIcon)}" alt="Valeur floutée" class="blur-icon" /></td>
                            </tr>
                            <tr>
                                <td class="turpe-bold">HPE</td>
                                <td><apex:outputText value="{0,number,### ### ##0.00}"><apex:param value="{!lstQLITurpe[0].HPEActuel__c}" /></apex:outputText></td>
                                <td><img src="{!URLFOR($Resource.BlurIcon)}" alt="Valeur floutée" class="blur-icon" /></td>
                            </tr>
                            <tr>
                                <td class="turpe-bold">HCH</td>
                                <td><apex:outputText value="{0,number,### ### ##0.00}"><apex:param value="{!lstQLITurpe[0].HCHActuel__c}" /></apex:outputText></td>
                                <td><img src="{!URLFOR($Resource.BlurIcon)}" alt="Valeur floutée" class="blur-icon" /></td>
                            </tr>
                            <tr>
                                <td class="turpe-bold">HPH</td>
                                <td><apex:outputText value="{0,number,### ### ##0.00}"><apex:param value="{!lstQLITurpe[0].HPHActuel__c}" /></apex:outputText></td>
                                <td><img src="{!URLFOR($Resource.BlurIcon)}" alt="Valeur floutée" class="blur-icon" /></td>
                            </tr>
                            <tr>
                                <td class="turpe-bold">POINTE</td>
                                <td><apex:outputText value="{0,number,### ### ##0.00}"><apex:param value="{!lstQLITurpe[0].POINTEActuel__c}" /></apex:outputText></td>
                                <td><img src="{!URLFOR($Resource.BlurIcon)}" alt="Valeur floutée" class="blur-icon" /></td>
                            </tr>

                            <tr>
                                <td class="turpe-category" rowspan="5">
                                    COMPOSANTES<br/>OPTIMISABLES DU<br/>TURPE
                                </td>
                                <td class="turpe-bold">Part fixe de la CS</td>
                                <td>
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!lstQLITurpe[0].PartFixeCSActuel__c}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                                <td class="{!cssPartFixeCS}">
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!lstQLITurpe[0].PartFixeCSOptimal__c}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                            </tr>
                            <tr>
                                <td class="turpe-bold">Part variable de la CS</td>
                                <td>
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!lstQLITurpe[0].PartVariableCSActuel__c}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                                <td class="{!cssPartVariableCS}">
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!lstQLITurpe[0].PartVariableCSOptimal__c}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                            </tr>
                            <tr>
                                <td class="turpe-bold">Dépassements</td>
                                <td>
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!lstQLITurpe[0].DepassementActuel__c}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                                <td class="{!cssDepassement}">
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!lstQLITurpe[0].DepassementOptimal__c}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                            </tr>
                            <tr>
                                <td class="turpe-bold">Taxe CTA</td>
                                <td>
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!lstQLITurpe[0].TaxeCTAActuel__c}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                                <td class="{!cssTaxeCTA}">
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!lstQLITurpe[0].TaxeCTAOptimal__c}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                            </tr>
                            <tr>
                                <td class="turpe-bold">Intervention PEP'S</td>
                                <td>-</td>
                                <td class="{!cssInterventionPEPS}">
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!lstQLITurpe[0].InterventionPEPS__c}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                            </tr>
                            <tr class="turpe-total">
                                <td colspan="2">TOTAL</td>
                                <td>
                                    <apex:outputText value="{0,number,### ### ##0.00}">
