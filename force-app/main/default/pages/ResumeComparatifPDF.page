                            </tbody>
                        </table>
                    </apex:outputPanel>
                    <!-- /GAZ -->

                    <!-- FOOTER -->
                    <div class="go-footer">
                        <div>- Rythme de facturation annuel par défaut<br/>
                            - Rythme de livraison annuel par défaut</div>
                        <div style="text-align:right;">* 1 MWh = 1 Garantie d'origine renouvelable</div>
                    </div>
                    <!-- /FOOTER -->

                </div>
            </div>
        </apex:outputPanel>
        <!-- /Garanties d’Origine -->
        <!-- SECTION OPTIMISATION TURPE -->
