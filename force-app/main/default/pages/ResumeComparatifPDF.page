                                    </apex:outputText>&nbsp;€
                                </td>
                                <td class="{!cssBudgetTotal}">
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!lstQLITurpe[0].BudgetTotalOptimal__c}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="turpe-note">
                        <p>- Un changement de dénivelé de puissance coûte <b>68 € HT</b> auprès d'ENEDIS — 
                            Un changement de version d'utilisation coûte <b>20 € HT</b> auprès d'ENEDIS.</p>
                        <p><i>{!noteDateText}</i></p>
                        <apex:outputText rendered="{!showTurpeMono}" value="{!noteConsoText}" escape="false" />
                    </div>
                </div>
            </div>
        </apex:outputPanel>
        <!-- Section Optimisation TURPE - Vue Multisite -->
        <apex:outputPanel rendered="{!showTurpeMulti}">
            <div class="contentPage page-break-always">
                <div class="paddingAround turpe-tight">
                    <h2 class="section-title">Mon optimisation TURPE potentielle</h2>
                    <table class="turpe-table">
                        <thead>
                            <tr>
                                <th style="width: 35%;">Informations du compteur</th>
                                <th style="width: 20%;">Budget TURPE Actuel (€HT/an)</th>
                                <th style="width: 20%;">Budget TURPE Optimal (€HT/an)</th>
                                <th style="width: 25%;">Économie identifiée (€HT/an)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <apex:repeat value="{!lstQLITurpe}" var="qli">
                                <tr>
                                    <td>{!qli.PDE__r.Name}</td>
                                    <td>
                                        <apex:outputText value="{0,number,### ### ##0.00}">
                                            <apex:param value="{!qli.BudgetTotalActuel__c}" />
                                        </apex:outputText>&nbsp;€
                                    </td>
                                    <td class="{!
                                        IF(
                                            (IF(ISBLANK(qli.BudgetTotalOptimal__c), 0, qli.BudgetTotalOptimal__c)) > 
                                            (IF(ISBLANK(qli.BudgetTotalActuel__c), 0, qli.BudgetTotalActuel__c)),
                                            'turpe-negative',
                                            IF(
                                                (IF(ISBLANK(qli.BudgetTotalOptimal__c), 0, qli.BudgetTotalOptimal__c)) < 
                                                (IF(ISBLANK(qli.BudgetTotalActuel__c), 0, qli.BudgetTotalActuel__c)),
                                                'turpe-positive',
                                                ''
                                            )
                                        )
                                    }">
                                        <apex:outputText value="{0,number,### ### ##0.00}">
                                            <apex:param value="{!qli.BudgetTotalOptimal__c}" />
                                        </apex:outputText>&nbsp;€
                                    </td>
                                    <td style="font-size:14px; font-weight: bold;">
                                        <apex:outputText value="{0,number,### ### ##0.00}">
                                            <apex:param value="{!qli.EconomieIdentifie__c}" />
                                        </apex:outputText>&nbsp;€
                                    </td>
                                </tr>
                            </apex:repeat>

                            <!-- ======== LIGNE DE TOTAL GLOBAL ======== -->
                            <tr class="turpe-total">
                                <td style="font-weight: bold;">TOTAL GLOBAL</td>
                                <td>
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!totalBudgetActuel}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                                <td class="{!cssBudgetTotalMulti}">
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!totalBudgetOptimal}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                                <td style="font-size:14px; font-weight: bold;">
                                    <apex:outputText value="{0,number,### ### ##0.00}">
                                        <apex:param value="{!totalEconomie}" />
                                    </apex:outputText>&nbsp;€
                                </td>
                            </tr>
                        </tbody>
                    </table>
                
                    <div class="turpe-note">
                        <p>- Un changement de dénivelé de puissance coûte <b>68 € HT</b> auprès d'ENEDIS — 
                            Un changement de version d'utilisation coûte <b>20 € HT</b> auprès d'ENEDIS.</p>
                        <p><i>{!noteDateText}</i></p>
                    </div>
                </div>
            </div>
        </apex:outputPanel>
