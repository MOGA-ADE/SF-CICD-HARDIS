<apex:page renderAs="pdf" controller="VFC008_ResumeComparatifPDFController" applyBodyTag="false" applyHtmlTag="false" showHeader="false">
<apex:stylesheet value="{!URLFOR($Resource.EtudeComparative)}"/>
    <head>
        <style>
        @page content_page{
            size: A4 landscape;
            margin: 0cm;
            padding-top: 30px;
            padding-bottom: 30px;
            background-color: white;
        }

        @page {
            size: A4 landscape;
            margin: 0cm;
            padding: 0cm;
            background-color: #031728;
        }

        .contentPage {
            page: content_page;
        }

        .pagenumber:before {
            content: counter(page);
        }

        .pagecount:before {
            content: counter(pages);
        }

        body, * {
          margin: 0;
          padding: 0;
          font-family: Arial, Helvetica, sans-serif;
          font-size: 10px;
          color: #1E1E1E;
          box-sizing: border-box;
        }

        table {
            width: 100%;
            margin-top: 40px;
            border-collapse: collapse;
            page-break-inside: auto;
        }

        tr {
            page-break-inside: avoid; 
            page-break-after: auto;
        }

        th, td {
            border: 1px solid white;
            border-bottom: none;
            padding: 8px;
            vertical-align: middle;
            text-align: center;
        }

        th {
            color: white;
            font-weight: bold;
            background-color: #196C75;
        }

        td {
            background-color: #EAEAEA;
        }

        h1 {
            margin: 0;
            color: #196C75;
            font-size: 28px;
        }

        footer {
            position: fixed;
            bottom: 10px;
            width: 99%;
            text-align: right;
            font-size: 14px;
            color: #196C75;
        }

        .page {
            width: 29.7cm;
            height: 20.9cm; 
            position: relative;
        }

        .page-break-auto {
            page-break-after: auto;
        }

        .page-break-always {
            page-break-after: always;
        }

        .fullContent {
            width: 100%;
            height: 100%;
        }

        .paddingAround {
            width: 90%;
            height: 100%;
            padding-left: 5%;
            padding-right: 5%;
        }

        .siteSeparator {
            border: none;
            background-color: transparent;
        }

        .metallicBlue {
            background-color: #27457A;
        }

        .light-metallicBlue {
            background-color: #4366a3;
        }

        .deepCarrot {
            background-color: #E56633;
        }

        .beer {
            background-color: #F28D20;
        }

        .crystal {
            background-color: #44acb9;
        }

        .light-crystal {
            background-color: #70c7d3;
        }

        .darkyellow {
            background-color: #f7bf28;
        }

        .yellow {
            background-color: #FFD666;
        }

        .fontDeepCarrot {
            color: #E56633;
        }

        .accueilTextBlock {
            position: absolute;
            bottom: 8%;
            left: 5%;
            right: 5%;
            width: 90%;
            color: #2c3e63;
        }

        .accueilTextBlock h1 {
            font-size: 28px;
            font-weight: bold;
            margin-bottom: 20px;
            color: #2c3e63;
        }

        .accueilTextBlock .accueilSeparator {
            font-size: 16px;
        }

        .accueilTextBlock p.commercialName {
            margin-top: 4px;
            margin-bottom: 10px;
            font-size: 18px;
            font-weight: bold;
        }

        .accueilTextBlock p {
            margin-top: 5px;
            font-size: 14px;
            color: #2c3e63;
        }

        .accueilDateBlock {
            position: absolute;
            bottom: 0;
            right: 0;
            color: #2c3e63;
            font-weight: bold;
        }

        .boldFournisseur {
            font-weight: bold;
            font-size: 16px;
        }

        /* --- GO slide fine-tuning (look maquette) --- */
        .go-title { margin: 0 0 6px 0; color: #196C75; font-size: 26px; }
        .go-sub { margin: 6px 0 8px 0; color: #196C75; font-size: 16px; }
        .go-legend { margin-top: 8px; font-size: 11px; color: #1E1E1E; }
        .go-section { margin-top: 16px; display: flex; align-items: center; gap: 8px; }
        .go-icon { height: 18px; vertical-align: middle; }
        .go-flag {
            width: 20px;
            height: auto;
            margin-right: 5px;
            vertical-align: middle;
        }
        .go-tight table { margin-top: 12px; }
        .go-tight th, .go-tight td { padding: 6px 8px; }
        .go-tight th { font-size: 10px; }
        .go-tight td { font-size: 10px; }
        .go-right { text-align: right; }
        .go-strong { font-weight: bold; }
        .go-icon {
            height: 18px;
            display: inline-block;
            vertical-align: middle;
            margin-right: 6px;
            margin-top: -3px;
        }
        .go-section img.go-icon {
            height: 20px;
            display: inline-block;
            vertical-align: middle;
            margin-right: 6px;
            margin-top: -2px;
        }
        .go-section h2 {
            display: inline-block;
            vertical-align: middle;
            margin: 0;
        }
        .section-title {
            font-size: 22px;
            font-weight: bold;
            color: #004d4d;
            margin-bottom: 15px;
        }
        .sub-title-elec {
            color: #196C75;
            font-size: 16px;
            margin: 10px 0;
        }
        .sub-title-gaz {
            color: #0d7c4d;
            font-size: 16px;
            margin: 10px 0;
        }
        .highlight {
            color: #0DA35B;
            font-weight: bold;
        }
L
        /* Harmonisation des tables GO avec les tables classiques */
        .comparatif-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 40px;
            page-break-inside: auto;
        }
        .comparatif-table th,
        .comparatif-table td {
            border: 1px solid white;
            padding: 8px;
            vertical-align: middle;
            text-align: center;
            font-size: 10px;
        }
        .comparatif-table th {
            color: white;
            font-weight: bold;
            background-color: #196C75;
        }
        .comparatif-table td {
            background-color: #EAEAEA;
        }
        .comparatif-table td.metallicBlueTD {
            background-color: #196C75;
            color: white;
            font-weight: bold;
        }
        .strong {
            font-weight: bold;
        }
        .numeric {
            text-align: right;
        }
        .go-footer {
            width: 100%;
            margin-top: 20px;
            font-size: 12px;
            display: flex;
            justify-content: space-between;
            color: #444;
        }
        .sub-title {
            font-size: 18px;
            font-weight: bold;
            color: #196C75; /* même vert pour Elec et Gaz */
            margin: 10px 0;
        }
        .sub-title .highlight {
            font-size: 16px;
            font-weight: normal;
            color: #0DA35B; /* vert clair pour mettre en avant */
        }
        img.go-reset-icon {
        height: 20px !important;
        width: 20px !important;
        max-height: none !important;
        max-width: none !important;
        object-fit: initial !important;
        }

            /* ==== SECTION OPTIMISATION TURPE ==== */

            /* Conteneur */
            .turpe-section {
                background-color: #ffffff !important; /* Force le fond blanc */
                padding: 20px;
                font-family: Arial, sans-serif;
                page-break-inside: avoid;
            }

            /* Bandeau supérieur (Économies identifiées) */
            .turpe-banner {
                background-color: #D9F2FA;
                text-align: center;
                padding: 12px;
                margin: 6px 0;
            }

            .turpe-banner-label {
                margin-right : 8%;
                font-size: 20px;
                font-weight: 700;
            }

            .turpe-banner-value {
                margin-left : 8%;
                font-size: 20px;
                font-weight: 700;
            }

            /* Tableau */
            .turpe-table {
                width: 100%;
                border-collapse: collapse;
                background-color: #ffffff;
                border: 1px solid #d9d9d9;
                text-align: center;
                font-size: 12px;
                color: #000;
            }

            .turpe-table td {
                height: 40px  !important;
                max-height: 40px  !important; /* Fixe la hauteur pour éviter les variations */
                overflow: hidden  !important; /* Empêche l’image de forcer la cellule */
            }

            .turpe-table th {
                background-color: #196C75; 
                color: white;
                padding: 8px;
                border: 1px solid #d9d9d9;
                font-weight: bold;
            }

            .turpe-table td img.blur-icon {
                width: 50px;      /* Taille fixe */
                height: 22px;     /* Taille fixe */
            }

            /* Lignes de catégorie à gauche */
            .turpe-category {
                background-color: #f3f4f6;
                font-weight: bold;
                text-transform: uppercase;
                font-size: 11px;
                color: #000;
            }

            /* Lignes totales */
            .turpe-total {
                background-color: #f3f4f6;
                font-weight: bold;
            }

            /* Valeurs positives et négatives */
            .turpe-positive {
                color: #009c2e;
                font-weight: bold;
            }

            .turpe-negative {
                color: #d0021b;
                font-weight: bold;
            }

            /* Texte de note */
            .turpe-note {
                font-size: 11px;
                color: #111;
                margin-top: 12px;
                line-height: 1.4;
            }
            .turpe-economies {
                background-color: #D9F2FA;
                text-align: center;
                font-size: 20px;
                font-weight: 700;
                padding: 10px 0;
                margin-bottom: 20px;
                letter-spacing: 0.5px;
            }

            /* Couleur verte pour valeurs optimales */
            .turpe-table td.optimal-value {
                color: #118C4F;
                font-weight: 600;
            }

            .turpe-th-header {
                background-color: #007c91; /* Bleu GO */
                color: white;
                padding: 8px;
                border: 1px solid #d9d9d9;
                font-weight: bold;
            }

            .turpe-th-header-empty {
                background-color: #007c91;
                border: 1px solid #d9d9d9;
                padding: 8px;
            }

            .turpe-th-sub {
                background-color: #EAEAEA !important;
                color: black !important;
                padding: 8px !important;
                border: 1px solid #d9d9d9 !important;
                font-weight: bold !important;
            }
            .turpe-bold {
                font-weight: bold !important;
            }
            /* ==== SECTION OPTIMISATION TURPE – VUE MULTISITE ==== */

        </style>
    </head>

    <body>
        <!--__________________
           |Page présentation|
        -->
        <div class="page page-break-always">
            <div class="fullContent">
                <div class="accueilTextBlock">
                    <h1 style="display:{!IF(isOppGaz,'','none')};">Résumé d'étude comparative gaz</h1>
                    <h1 style="display:{!IF(isOppGaz,'none','')};">Résumé d'étude comparative électricité</h1>
                    
                    <span class="accueilSeparator fontDeepCarrot">Pour</span>
                    <p class="commercialName">{!opp.Account.Name}</p><br/>
                    
                    <span class="accueilSeparator fontDeepCarrot">Présenté par</span>
                    <p class="commercialName">{!opp.Demande_Cotation__r.Owner.Name}</p>
                    <p>{!opp.Demande_Cotation__r.Owner.Email}</p>
                    <p>{!opp.Demande_Cotation__r.Owner.Phone}</p>

                    <p class="accueilDateBlock">Le {!todayDate}</p>
                </div>

                <img style="display:{!IF(isOppPartenaire,'none','')};" src="{!URLFOR($Resource.Comparatif2024_Accueil,'Accueil.jpg')}" width="29.7cm" height="21cm"/>
                <img style="display:{!IF(isOppPartenaire,'','none')};" src="{!URLFOR($Resource.Comparatif2024_Accueil,'AccueilPartenaires.jpg')}" width="29.7cm" height="21cm"/>
            </div>
        </div>

        <!-- _________________
            |Pages comparatif|
        -->
        <div class="contentPage page-break-auto">

            <!-- ____________________________________________
                |Fournisseurs séléctionnés & Budget globaux |
            -->
            <div class="paddingAround">

                <h1>Fournisseurs seléctionnés et Budget globaux</h1>

                <!-- Tableau Gaz -->
                <apex:outputPanel rendered="{!isOppGaz}">
                    <table class="page-break-always">
                        <thead>
                            <tr>
                                <th scope="rowgroup" rowspan="2">Fournisseur</th>
                                <th scope="rowgroup" rowspan="2">Date de début</th>
                                <th scope="rowgroup" rowspan="2">Date de fin</th>
                                <th scope="rowgroup" rowspan="2">Durée</th>
                                <th scope="rowgroup" rowspan="2">Type d'offre</th>
                                <th scope="row" colspan="1" class="metallicBlue">Énergie</th>
                                <th scope="row" colspan="1" class="crystal">Acheminement</th>
                                <th scope="row" colspan="1" class="deepCarrot">Taxes et Contributions</th>
                                <th scope="row" colspan="{!IF(showSectionTTC,'2','1')};" class="darkyellow">Budget total</th>
                            </tr>
                            <tr>
                                <th scope="row" class="light-metallicBlue">€/an</th>
                                <th scope="row" class="light-crystal">€/an</th>
                                <th scope="row" class="beer">€/an</th>
                                <th scope="row" class="yellow">HTVA/an</th>
                                <th scope="row" class="yellow" style="display:{!IF(showSectionTTC,'','none')};">TTC/an</th>
                            </tr>
                        </thead>
                        <tobdy>
                            <apex:repeat value="{!listBudgetGlobal}" var="bg">
                                <tr>
                                    <td>
                                        <apex:outputText value="{!bg.logo}" escape="false" rendered="{!bg.logo != 'None'}"/>
                                        <apex:outputText value="{!bg.fournisseur}" escape="false" rendered="{!bg.logo == 'None'}" styleClass="boldFournisseur"/><br/>
                                    </td>
                                    <td>
                                        <apex:outputText rendered="{!bg.fournisseur != 'Situation Actuelle'}" value="{0,date,dd'/'MM'/'yyyy}"><apex:param value="{!bg.dateDebut}"/></apex:outputText>
                                        <apex:outputText rendered="{!bg.fournisseur == 'Situation Actuelle'}" value="--"></apex:outputText>
                                    </td>
                                    <td><apex:outputText value="{0,date,dd'/'MM'/'yyyy}"><apex:param value="{!bg.dateFin}"/></apex:outputText></td>
                                    <td>
                                        <apex:outputText rendered="{!bg.fournisseur != 'Situation Actuelle'}" value="{!bg.dureeOffre} mois" escape="false"></apex:outputText>
                                        <apex:outputText rendered="{!bg.fournisseur == 'Situation Actuelle'}" value="--"></apex:outputText>
                                    </td>
                                    <td>{!bg.typeOffre}</td>
                                    <td><apex:outputText value="{0, number, ###,###,##0.00} €"><apex:param value="{!bg.BudgetEnergieGaz}"/></apex:outputText></td>
                                    <td><apex:outputText value="{0, number, ###,###,##0.00} €"><apex:param value="{!bg.BudgetAcheminementGaz}"/></apex:outputText></td>
                                    <td><apex:outputText value="{0, number, ###,###,##0.00} €"><apex:param value="{!bg.BudgetTaxeGaz}"/></apex:outputText></td>
                                    <td><span><strong><apex:outputText value="{0, number, ###,###,##0.00} €"><apex:param value="{!bg.TotalHTVAGaz}"/></apex:outputText></strong></span></td>
                                    <td style="display:{!IF(showSectionTTC,'','none')};"><span><strong><apex:outputText value="{0, number, ###,###,##0.00} €"><apex:param value="{!bg.TotalTTC}"/></apex:outputText></strong></span></td>
                                </tr>
                            </apex:repeat>
                        </tobdy>
                    </table>
                </apex:outputPanel>

                <!-- Tableaux Elec -->
                <apex:outputPanel rendered="{!NOT(isOppGaz)}">
                    <table class="page-break-always">
                        <thead>
                            <tr>
                                <th scope="rowgroup" rowspan="2">Fournisseur</th>
                                <th scope="rowgroup" rowspan="2">Date de début</th>
                                <th scope="rowgroup" rowspan="2">Date de fin</th>
                                <th scope="rowgroup" rowspan="2">Durée</th>
                                <th scope="rowgroup" rowspan="2">Type d'offre</th>
                                <th scope="row" colspan="1" class="metallicBlue">Énergie</th>
                                <th scope="row" colspan="1" class="crystal">Acheminement</th>
                                <th scope="row" colspan="1" class="deepCarrot">Taxes et Contributions</th>
                                <th scope="row" colspan="{!IF(showSectionTTC,'2','1')};" class="darkyellow">Budget total</th>
                            </tr>
                            <tr>
                                <th scope="row" class="light-metallicBlue">€/an</th>
                                <th scope="row" class="light-crystal">€/an</th>
                                <th scope="row" class="beer">€/an</th>
                                <th scope="row" class="yellow">HTVA/an</th>
                                <th scope="row" class="yellow" style="display:{!IF(showSectionTTC,'','none')};">TTC/an</th>
                            </tr>
                        </thead>
                        <tobdy>
                            <apex:repeat value="{!listBudgetGlobal}" var="bg">
                                <tr>
                                    <td>
                                        <apex:outputText value="{!bg.logo}" escape="false" rendered="{!bg.logo != 'None'}"/>
                                        <apex:outputText value="{!bg.fournisseur}" escape="false" rendered="{!bg.logo == 'None'}" styleClass="boldFournisseur"/><br/>
                                    </td>
                                    <td>
                                        <apex:outputText rendered="{!bg.fournisseur != 'Situation Actuelle'}" value="{0,date,dd'/'MM'/'yyyy}"><apex:param value="{!bg.dateDebut}"/></apex:outputText>
                                        <apex:outputText rendered="{!bg.fournisseur == 'Situation Actuelle'}" value="--"></apex:outputText>
                                    </td>
                                    <td><apex:outputText value="{0,date,dd'/'MM'/'yyyy}"><apex:param value="{!bg.dateFin}"/></apex:outputText></td>
                                    <td>
                                        <apex:outputText rendered="{!bg.fournisseur != 'Situation Actuelle'}" value="{!bg.dureeOffre} mois" escape="false"></apex:outputText>
                                        <apex:outputText rendered="{!bg.fournisseur == 'Situation Actuelle'}" value="--"></apex:outputText>
                                    </td>
                                    <td>{!bg.typeOffre}</td>
                                    <td><apex:outputText value="{0, number, ###,###,##0.00} €"><apex:param value="{!bg.BudgetEnergieElec}"/></apex:outputText></td>
                                    <td><apex:outputText value="{0, number, ###,###,##0.00} €"><apex:param value="{!bg.BudgetAcheminementElec}"/></apex:outputText></td>
                                    <td><apex:outputText value="{0, number, ###,###,##0.00} €"><apex:param value="{!bg.BudgetTaxeElec}"/></apex:outputText></td>
                                    <td><span><strong><apex:outputText value="{0, number, ###,###,##0.00} €"><apex:param value="{!bg.TotalHTVAElec}"/></apex:outputText></strong></span></td>
                                    <td style="display:{!IF(showSectionTTC,'','none')};"><span><strong><apex:outputText value="{0, number, ###,###,##0.00} €"><apex:param value="{!bg.TotalTTC}"/></apex:outputText></strong></span></td>
                                </tr>
                            </apex:repeat>
                        </tobdy>
                    </table>
                </apex:outputPanel>
            </div>

            <!-- ____________
                |Prix Moyen |
            -->
            <div class="paddingAround">

                <h1 style="display:{!IF(isOppGaz,'none','')};">Prix moyen par FTA</h1>
                <h1 style="display:{!IF(isOppGaz,'','none')};">Prix moyen par Tarif</h1>
                <span>*Les prix affichés sont une moyenne pondérée</span>

                <!-- Tableau Gaz -->
                <apex:outputPanel rendered="{!isOppGaz}">

                    <!-- T1 -->
                    <apex:outputPanel rendered="{!listprixMoyenT1NotEmpty}">
                        <table class="page-break-always">
                            <thead>
                                <tr>
                                    <th scope="rowgroup" rowspan="2">Tarif</th>
                                    <th scope="rowgroup" rowspan="2">Fournisseur</th>
                                    <th scope="rowgroup" rowspan="2">Type d'offre</th>
                                    <th scope="rowgroup" rowspan="2">Durée</th>
                                    <th scope="row" class="metallicBlue">Abonnement</th>
                                    <th scope="row" class="metallicBlue">Molécule</th>
                                    <th scope="row" class="metallicBlue">Distribution variable</th>
                                    <th scope="row" class="metallicBlue">CEE</th>
                                </tr>
                                <tr>
                                    <th scope="row" class="light-metallicBlue">(€/mois)</th>
                                    <th scope="row" class="light-metallicBlue">(€/MWh)</th>
                                    <th scope="row" class="light-metallicBlue">(€/MWh)</th>
                                    <th scope="row" class="light-metallicBlue">(€/MWh)</th>
                                </tr>
                            </thead>
                            <tobdy>
                                <apex:repeat value="{!listprixMoyenT1}" var="pm">
                                    <tr>
                                        <td>T1</td>
                                        <td>
                                            <apex:outputText value="{!pm.logo}" escape="false" rendered="{!pm.logo != 'None'}"/>
                                            <apex:outputText value="{!pm.fournisseur}" escape="false" rendered="{!pm.logo == 'None'}" styleClass="boldFournisseur"/><br/>
                                        </td>
                                        <td>{!pm.typeOffre}</td>
                                        <td>
                                            <apex:outputText rendered="{!pm.fournisseur != 'Situation Actuelle'}" value="{!pm.dureeOffre} mois" escape="false"></apex:outputText>
                                            <apex:outputText rendered="{!pm.fournisseur == 'Situation Actuelle'}" value="--"></apex:outputText>
                                        </td>
                                        <td>Voir l'étude détaillée</td>
                                        <td>
                                            <apex:outputText value="{0, number, ###,###,##0.00} €" escape="false"><apex:param value="{!pm.moleculeMoyennePonderee}"/></apex:outputText>
                                        </td>
                                        <td>
                                            <apex:outputText value="{0, number, ###,###,##0.00} €" escape="false" rendered="{!pm.fournisseur != 'Situation Actuelle'}"><apex:param value="{!pm.fraisDistributionVariable}"/></apex:outputText>
                                            <apex:outputText value="Voir l'étude détaillée" escape="false" rendered="{!pm.fournisseur == 'Situation Actuelle'}"/>
                                        </td>
                                        <td>
                                            <apex:outputText value="{0, number, ###,###,##0.00} €" escape="false" rendered="{!pm.tQuoteCee == 'Soumis'}"><apex:param value="{!pm.ceeMoyennePonderee}"/></apex:outputText>
                                            <apex:outputText value="{!pm.tQuoteCee}" escape="false" rendered="{!pm.tQuoteCee != 'Soumis'}"/>
                                        </td>
                                    </tr>
                                </apex:repeat>
                            </tobdy>
                        </table>
                    </apex:outputPanel>

                    <!-- T2 -->
                    <apex:outputPanel rendered="{!listprixMoyenT2NotEmpty}">
                        <table class="page-break-always">
                            <thead>
                                <tr>
                                    <th scope="rowgroup" rowspan="2">Tarif</th>
                                    <th scope="rowgroup" rowspan="2">Fournisseur</th>
                                    <th scope="rowgroup" rowspan="2">Type d'offre</th>
                                    <th scope="rowgroup" rowspan="2">Durée</th>
                                    <th scope="row" class="metallicBlue">Abonnement</th>
                                    <th scope="row" class="metallicBlue">Molécule</th>
                                    <th scope="row" class="metallicBlue">Distribution variable</th>
                                    <th scope="row" class="metallicBlue">CEE</th>
                                </tr>
                                <tr>
