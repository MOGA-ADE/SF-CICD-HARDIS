<apex:page renderAs="pdf" controller="VFC007_ComparatifPDFController" applyBodyTag="false" applyHtmlTag="false" showHeader="false">

    <head>
        <style>
            @page content_page{
                size: A4 landscape;
                margin: 0cm;
                padding-top: 20px;
                padding-bottom: 20px;
                background-color: white;
            }

            @page {
                size: A4 landscape;
                margin: 0cm;
                padding: 0cm;
                background-color: #031728;
            }

            .contentPage {
                page: content_page;
            }

            .pagenumber:before {
                content: counter(page);
            }

            .pagecount:before {
                content: counter(pages);
            }

            body, * {
              margin: 0;
              padding: 0;
              font-family: Arial, Helvetica, sans-serif;
              font-size: 10px;
              color: #1E1E1E;
              box-sizing: border-box;
            }

            table {
                width: 100%;
                margin-top: 40px;
                border-collapse: collapse;
                page-break-inside: auto;
            }

            tr {
                page-break-inside: avoid; 
                page-break-after: auto;
            }

            th, td {
                border: 1px solid white;
                border-bottom: none;
                padding: 8px;
                vertical-align: middle;
                text-align: center;
            }

            th {
                color: white;
                font-weight: bold;
                background-color: #196C75;
            }

            td {
                background-color: #EAEAEA;
            }

            h1 {
                margin: 0;
                color: #196C75;
                font-size: 28px;
            }

            footer {
                position: fixed;
                bottom: 10px;
                width: 99%;
                text-align: right;
                font-size: 14px;
                color: #196C75;
            }

            .page {
                width: 29.7cm;
                height: 20.9cm; 
                position: relative;
            }

            .page-break-auto {
                page-break-after: auto;
            }

            .page-break-always {
                page-break-after: always;
            }

            .fullContent {
                width: 100%;
                height: 100%;
            }

            .paddingAround {
                width: 90%;
                height: 100%;
                padding-left: 5%;
                padding-right: 5%;
            }

            .siteSeparator {
                border: none;
                background-color: transparent;
            }

            .metallicBlue {
                background-color: #27457A;
            }

            .light-metallicBlue {
                background-color: #4366a3;
            }

            .deepCarrot {
                background-color: #E56633;
            }

            .beer {
                background-color: #F28D20;
            }

            .crystal {
                background-color: #44acb9;
            }

            .light-crystal {
                background-color: #70c7d3;
            }

            .darkyellow {
                background-color: #f7bf28;
            }

            .yellow {
                background-color: #FFD666;
            }

            .metallicBlueTD {
                background-color: #4366a3;
                color: white;
                font-weight: bold;
            }

            .fontDeepCarrot {
                color: #E56633;
            }

            .accueilTextBlock {
                position: absolute;
                bottom: 8%;
                left: 5%;
                right: 5%;
                width: 90%;
                color: #2c3e63;
            }

            .accueilTextBlock h1 {
                font-size: 28px;
                font-weight: bold;
                margin-bottom: 20px;
                color: #2c3e63;
            }

            .accueilTextBlock .accueilSeparator {
                font-size: 16px;
            }

            .accueilTextBlock p.commercialName {
                margin-top: 4px;
                margin-bottom: 10px;
                font-size: 18px;
                font-weight: bold;
            }

            .accueilTextBlock p {
                margin-top: 5px;
                font-size: 14px;
                color: #2c3e63;
            }

            .accueilDateBlock {
                position: absolute;
                bottom: 0;
                right: 0;
                color: #2c3e63;
                font-weight: bold;
            }

            .boldFournisseur {
                font-weight: bold;
                font-size: 16px;
            }

            /* --- GO slide fine-tuning (look maquette) --- */
            .go-title { margin: 0 0 6px 0; color: #196C75; font-size: 26px; }
            .go-sub { margin: 6px 0 8px 0; color: #196C75; font-size: 16px; }
            .go-legend { margin-top: 8px; font-size: 11px; color: #1E1E1E; }
            .go-section { margin-top: 16px; display: flex; align-items: center; gap: 8px; }
            .go-icon { height: 18px; vertical-align: middle; }
            .go-flag {
                width: 20px;
                height: auto;
                margin-right: 5px;
                vertical-align: middle;
            }

            .go-tight table { margin-top: 12px; }
            .go-tight th, .go-tight td { padding: 6px 8px; }
            .go-tight th { font-size: 10px; }
            .go-tight td { font-size: 10px; }
            .go-right { text-align: right; }
            .go-strong { font-weight: bold; }
            .go-icon {
                height: 18px;
                display: inline-block;
                vertical-align: middle;
                margin-right: 6px;
                margin-top: -3px; /* petit ajustement pour coller au texte */
            }
            .go-section img.go-icon {
                height: 20px; /* un poil plus grand pour matcher la taille du texte */
                display: inline-block;
                vertical-align: middle;
                margin-right: 6px;
                margin-top: -2px; /* petit correctif de pixel pour que ça colle parfaitement */
            }

            .go-section h2 {
                display: inline-block;
                vertical-align: middle;
                margin: 0;
            }

            .section-title {
                font-size: 22px;
                font-weight: bold;
                color: #004d4d;
                margin-bottom: 15px;
            }

            .sub-title-elec {
                color: #196C75;
                font-size: 16px;
                margin: 10px 0;
            }

            .sub-title-gaz {
                color: #0d7c4d;
                font-size: 16px;
                margin: 10px 0;
            }

            .highlight {
                color: #0DA35B;
                font-weight: bold;
            }
            
            /* Harmonisation des tables GO avec les tables classiques */
            .comparatif-table {
                width: 100%;
                border-collapse: collapse;
                margin-top: 40px; /* identique aux autres tables */
                page-break-inside: auto;
            }

            .comparatif-table th,
            .comparatif-table td {
                border: 1px solid white;
                padding: 8px; /* identique aux autres */
                vertical-align: middle;
                text-align: center;
                font-size: 10px; /* comme les autres tableaux */
            }

            .comparatif-table th {
                color: white;
                font-weight: bold;
                background-color: #196C75; /* bleu identique */
            }

            .comparatif-table td {
                background-color: #EAEAEA; /* gris identique */
            }

            /* Optionnel : pour que le budget ressorte en bleu, comme ailleurs */
            .comparatif-table td.metallicBlueTD {
                background-color: #196C75;
                color: white;
                font-weight: bold;
            }


            .strong {
                font-weight: bold;
            }

            .numeric {
                text-align: right;
            }

            .go-footer {
                width: 100%;
                margin-top: 20px;
                font-size: 12px;
                display: flex;
                justify-content: space-between;
                color: #444;
            }
            .sub-title {
                font-size: 18px;
                font-weight: bold;
                color: #196C75; /* même vert pour Elec et Gaz */
                margin: 10px 0;
            }

            .sub-title .highlight {
                font-size: 16px;
                font-weight: normal;
                color: #0DA35B; /* vert clair pour mettre en avant */
            }

            /* ==== SECTION OPTIMISATION TURPE ==== */

            /* Conteneur */
            .turpe-section {
                background-color: #ffffff !important; /* Force le fond blanc */
                padding: 20px;
                font-family: Arial, sans-serif;
                page-break-inside: avoid;
            }

            /* Bandeau supérieur (Économies identifiées) */
            .turpe-banner {
                background-color: #D9F2FA;
                text-align: center;
                padding: 12px;
                margin: 6px 0;
            }

            .turpe-banner-label {
                margin-right : 8%;
                font-size: 20px;
                font-weight: 700;
            }

            .turpe-banner-value {
                margin-left : 8%;
                font-size: 20px;
                font-weight: 700;
            }

            /* Tableau */
            .turpe-table {
                width: 100%;
                border-collapse: collapse;
                background-color: #ffffff;
                border: 1px solid #d9d9d9;
                text-align: center;
                font-size: 12px;
                color: #000;
            }

            .turpe-table td {
                height: 40px  !important;
                max-height: 40px  !important; /* Fixe la hauteur pour éviter les variations */
                overflow: hidden  !important; /* Empêche l’image de forcer la cellule */
            }

            .turpe-table th {
                background-color: #196C75; 
                color: white;
                padding: 8px;
                border: 1px solid #d9d9d9;
                font-weight: bold;
            }

            .turpe-table td img.blur-icon {
                width: 50px;      /* Taille fixe */
                height: 22px;     /* Taille fixe */
            }

            /* Lignes de catégorie à gauche */
            .turpe-category {
                background-color: #f3f4f6;
                font-weight: bold;
                text-transform: uppercase;
                font-size: 11px;
                color: #000;
            }

            /* Lignes totales */
            .turpe-total {
                background-color: #f3f4f6;
                font-weight: bold;
            }

            /* Valeurs positives et négatives */
            .turpe-positive {
                color: #009c2e;
                font-weight: bold;
            }

            .turpe-negative {
                color: #d0021b;
                font-weight: bold;
            }

            /* Texte de note */
            .turpe-note {
                font-size: 11px;
                color: #111;
                margin-top: 12px;
                line-height: 1.4;
            }
            .turpe-economies {
                background-color: #D9F2FA;
                text-align: center;
                font-size: 20px;
                font-weight: 700;
                padding: 10px 0;
                margin-bottom: 20px;
                letter-spacing: 0.5px;
            }

            /* Couleur verte pour valeurs optimales */
            .turpe-table td.optimal-value {
                color: #118C4F;
                font-weight: 600;
            }

            .turpe-th-header {
                background-color: #007c91; /* Bleu GO */
                color: white;
                padding: 8px;
                border: 1px solid #d9d9d9;
                font-weight: bold;
            }

            .turpe-th-header-empty {
                background-color: #007c91;
                border: 1px solid #d9d9d9;
                padding: 8px;
            }

            .turpe-th-sub {
                background-color: #EAEAEA !important;
                color: black !important;
                padding: 8px !important;
                border: 1px solid #d9d9d9 !important;
                font-weight: bold !important;
            }
            .turpe-bold {
                font-weight: bold !important;
            }
            /* ==== SECTION OPTIMISATION TURPE – VUE MULTISITE ==== */

        </style>
    </head>

    <body>
        <!--__________________
           |Page présentation|
        -->
        <div class="page page-break-always">
            <div class="fullContent">
                <div class="accueilTextBlock">
                    <h1 style="display:{!IF(isOppGaz,'','none')};">Étude comparative gaz</h1>
                    <h1 style="display:{!IF(isOppGaz,'none','')};">Étude comparative électricité</h1>

                    <span class="accueilSeparator fontDeepCarrot">Pour</span>
                    <p class="commercialName">{!accountName}</p><br/>

                    <span class="accueilSeparator fontDeepCarrot">Présenté par</span>
                    <p class="commercialName">{!commercialName}</p>
                    <p>{!commercialEmail}</p>
                    <p>{!commercialPhone}</p>

                    <p class="accueilDateBlock">Le {!todayDate}</p>
                </div>

                <img style="display:{!IF(isOppPartenaire,'none','')};" src="{!URLFOR($Resource.Comparatif2024_Accueil,'Accueil.jpg')}" width="29.7cm" height="21cm"/>
                <img style="display:{!IF(isOppPartenaire,'','none')};" src="{!URLFOR($Resource.Comparatif2024_Accueil,'AccueilPartenaires.jpg')}" width="29.7cm" height="21cm"/>
            </div>
        </div>

        <!-- _________________
            |Pages comparatif|
        -->
        <div class="contentPage page-break-auto">
            <!-- _________________
                |Périmètre actuel|
            -->
            <div class="paddingAround">
                <h1>Votre périmètre actuel : {!PDENumber}</h1>

                <!-- Tableau Gaz -->
                <apex:outputPanel rendered="{!isOppGaz}">
                    <table class="page-break-always">
                        <tr>
                            <th>Nom du site</th>
                            <th>Adresse du site</th>
                            <th>SIRET</th>
                            <th>Numéro de compteur</th>
                            <th>Tarif&nbsp;-&nbsp;Profil</th>
                            <th>Fournisseur actuel</th>
                            <th>Échéance de votre<br/>contrat actuel</th>
                            <th>Conso annuelle<br/>en MWh</th>
                        </tr>
                    
                        <apex:repeat value="{!listOPR}" var="OPR">
                            <tr>
                                <td>{!OPR.PDE__r.Name}</td>
                                <td>{!OPR.PDE__r.Adresse_de_consommation__c}</td>
                                <td>{!OPR.PDE__r.Siret_payeur__c}</td>
                                <td>{!OPR.PDE__r.TECH_num_compteur__c}</td>
                                <td>{!OPR.PDE__r.Tarif__c} - {!OPR.PDE__r.Profil__c}</td>
                                <td>{!OPR.PDE__r.Fournisseur__c}</td>
                                <td><apex:outputText value="{0,date,dd'/'MM'/'yyyy}"><apex:param value="{!OPR.PDE__r.DateEcheance__c}"/></apex:outputText></td>
                                <td class="metallicBlueTD"><apex:outputText value="{0, number, ###,###,##0.00}" escape="false"><apex:param value="{!OPR.PDE__r.TECH_CAR__c}"/></apex:outputText></td>
                            </tr>
                        </apex:repeat>
                    </table>
                </apex:outputPanel>

                <!-- Tableau Elec -->
                <apex:outputPanel rendered="{!NOT(isOppGaz)}">
                    <table class="page-break-always">
                        <tr>
                            <th>Nom du site</th>
                            <th>Adresse du site</th>
                            <th>SIRET</th>
                            <th>Numéro de compteur</th>
                            <th>Type de compteur</th>
                            <th>Fournisseur actuel</th>
                            <th>Échéance de votre<br/>contrat actuel</th>
                            <th>Conso annuelle<br/>en MWh</th>
                        </tr>
                    
                        <apex:repeat value="{!listOPR}" var="OPR">
                            <tr>
                                <td>{!OPR.PDE__r.Name}</td>
                                <td>{!OPR.PDE__r.Adresse_de_consommation__c}</td>
                                <td>{!OPR.PDE__r.Siret_payeur__c}</td>
                                <td>{!OPR.PDE__r.TECH_num_compteur__c}</td>
                                <td>{!OPR.PDE__r.Segment__c} - {!OPR.PDE__r.TECH_Short_FTA__c}</td>
                                <td>{!OPR.PDE__r.Fournisseur__c}</td>
                                <td><apex:outputText value="{0,date,dd'/'MM'/'yyyy}"><apex:param value="{!OPR.PDE__r.DateEcheance__c}"/></apex:outputText></td>
                                <td class="metallicBlueTD"><apex:outputText value="{0, number, ###,###,##0.00}" escape="false"><apex:param value="{!OPR.PDE__r.TECH_CAR__c}"/></apex:outputText></td>
                            </tr>
                        </apex:repeat>
                    </table>
                </apex:outputPanel>
            </div>

            <!-- _______________________
                |Conso Périmètre actuel|
            -->
            <div class="paddingAround" style="display:{!IF(isOppGaz,'none','')};">
                <h1>Consommation détaillée de votre périmètre</h1>

                <!-- Tableau Elec -->
                <apex:outputPanel rendered="{!NOT(isOppGaz)}">
                    <table class="page-break-always">
                        <thead>
                            <tr>
                                <th scope="rowgroup" rowspan="2">Nom du site</th>
                                <th scope="rowgroup" rowspan="2">Adresse du site</th>
                                <th scope="rowgroup" rowspan="2">Numéro de compteur</th>
                                <th scope="rowgroup" rowspan="2">Type de compteur</th>
                                <th scope="row" colspan="8" class="metallicBlue">Consommation annuelle en MWh</th>
                            </tr>
                            <tr>
                                <th scope="row" class="light-metallicBlue">BASE</th>
                                <th scope="row" class="light-metallicBlue">HP</th>
                                <th scope="row" class="light-metallicBlue">HC</th>
                                <th scope="row" class="light-metallicBlue">POINTE</th>
                                <th scope="row" class="light-metallicBlue">HPH</th>
                                <th scope="row" class="light-metallicBlue">HCH</th>
                                <th scope="row" class="light-metallicBlue">HPE</th>
                                <th scope="row" class="light-metallicBlue">HCE</th>
                            </tr>
                        </thead>
                    
                        <apex:repeat value="{!listOPR}" var="OPR">
                            <tr>
                                <td>{!OPR.PDE__r.Name}</td>
                                <td>{!OPR.PDE__r.Adresse_de_consommation__c}</td>
                                <td>{!OPR.PDE__r.TECH_num_compteur__c}</td>
                                <td>{!OPR.PDE__r.Segment__c} - {!OPR.PDE__r.TECH_Short_FTA__c}</td>
                                <td>
                                    <apex:outputText value="{!OPR.PDE__r.Conso_Base__c}" escape="false" rendered="{!OPR.PDE__r.Conso_Base__c != 0 && (OPR.PDE__r.FTA__c == 'BT <= 36 kVA - CU' || OPR.PDE__r.FTA__c == 'BT <= 36 kVA - LU EP' )}"/>
                                    <apex:outputText value="--" escape="false" rendered="{!OPR.PDE__r.Conso_Base__c == 0 || (OPR.PDE__r.FTA__c != 'BT <= 36 kVA - CU' && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - LU EP')}"/><br/>
                                </td>
                                <td>
                                    <apex:outputText value="{!OPR.PDE__r.ConsoHP__c}" escape="false" rendered="{!OPR.PDE__r.ConsoHP__c != 0 && OPR.PDE__r.FTA__c == 'BT <= 36 kVA - MU'}"/>
                                    <apex:outputText value="--" escape="false" rendered="{!OPR.PDE__r.ConsoHP__c == 0 || OPR.PDE__r.FTA__c != 'BT <= 36 kVA - MU'}"/><br/>
                                </td>
                                <td>
                                    <apex:outputText value="{!OPR.PDE__r.ConsoHC__c}" escape="false" rendered="{!OPR.PDE__r.ConsoHC__c != 0 && OPR.PDE__r.FTA__c == 'BT <= 36 kVA - MU'}"/>
                                    <apex:outputText value="--" escape="false" rendered="{!OPR.PDE__r.ConsoHC__c == 0 || OPR.PDE__r.FTA__c != 'BT <= 36 kVA - MU'}"/><br/>
                                </td>
                                <td>
                                    <apex:outputText value="{!OPR.PDE__r.Conso_Pointe__c}" escape="false" rendered="{!OPR.PDE__r.Conso_Pointe__c != 0 && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - CU' && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - LU EP' && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - MU'}"/>
                                    <apex:outputText value="--" escape="false" rendered="{!OPR.PDE__r.Conso_Pointe__c == 0 || OPR.PDE__r.FTA__c == 'BT <= 36 kVA - CU' || OPR.PDE__r.FTA__c == 'BT <= 36 kVA - LU EP'|| OPR.PDE__r.FTA__c == 'BT <= 36 kVA - MU'}"/><br/>
                                </td>
                                <td>
                                    <apex:outputText value="{!OPR.PDE__r.Conso_HPH__c}" escape="false" rendered="{!OPR.PDE__r.Conso_HPH__c != 0 && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - CU' && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - LU EP' && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - MU'}"/>
                                    <apex:outputText value="--" escape="false" rendered="{!OPR.PDE__r.Conso_HPH__c == 0 || OPR.PDE__r.FTA__c == 'BT <= 36 kVA - CU' || OPR.PDE__r.FTA__c == 'BT <= 36 kVA - LU EP'|| OPR.PDE__r.FTA__c == 'BT <= 36 kVA - MU'}"/><br/>
                                </td>
                                <td>
                                    <apex:outputText value="{!OPR.PDE__r.Conso_HCH__c}" escape="false" rendered="{!OPR.PDE__r.Conso_HCH__c != 0 && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - CU' && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - LU EP' && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - MU'}"/>
                                    <apex:outputText value="--" escape="false" rendered="{!OPR.PDE__r.Conso_HCH__c == 0 || OPR.PDE__r.FTA__c == 'BT <= 36 kVA - CU' || OPR.PDE__r.FTA__c == 'BT <= 36 kVA - LU EP'|| OPR.PDE__r.FTA__c == 'BT <= 36 kVA - MU'}"/><br/>
                                </td>
                                <td>
                                    <apex:outputText value="{!OPR.PDE__r.Conso_HPE__c}" escape="false" rendered="{!OPR.PDE__r.Conso_HPE__c != 0 && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - CU' && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - LU EP' &&  OPR.PDE__r.FTA__c != 'BT <= 36 kVA - MU'}"/>
                                    <apex:outputText value="--" escape="false" rendered="{!OPR.PDE__r.Conso_HPE__c == 0 || OPR.PDE__r.FTA__c == 'BT <= 36 kVA - CU' || OPR.PDE__r.FTA__c == 'BT <= 36 kVA - LU EP'|| OPR.PDE__r.FTA__c == 'BT <= 36 kVA - MU'}"/><br/>
                                </td>
                                <td>
                                    <apex:outputText value="{!OPR.PDE__r.Conso_HCE__c}" escape="false" rendered="{!OPR.PDE__r.Conso_HCE__c != 0 && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - CU' && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - LU EP' && OPR.PDE__r.FTA__c != 'BT <= 36 kVA - MU'}"/>
                                    <apex:outputText value="--" escape="false" rendered="{!OPR.PDE__r.Conso_HCE__c == 0 || OPR.PDE__r.FTA__c == 'BT <= 36 kVA - CU' || OPR.PDE__r.FTA__c == 'BT <= 36 kVA - LU EP'|| OPR.PDE__r.FTA__c == 'BT <= 36 kVA - MU'}"/><br/>
                                </td>
                            </tr>
                        </apex:repeat>
                    </table>
                </apex:outputPanel>
            </div>

            <!-- ___________________________
                |Offres énergie détaillées |
            -->
            <div class="paddingAround">
                
                <h1 style="display:{!IF(isOppGaz,'','none')};">Offres énergie et acheminement détaillées</h1>
                <h1 style="display:{!IF(isOppGaz,'none','')};">Offres énergie détaillées</h1>
                <span style="display:{!IF(isOppGaz,'','none')};">*Abonnement = ATRT + ATRD fixe + Stockage + part fixe fournisseur</span>
                
                <!-- Tableau Gaz -->
                <apex:outputPanel rendered="{!isOppGaz}">
                    <table class="page-break-always">
                        <thead>
                            <tr>
                                <th scope="rowgroup" rowspan="2">Fournisseur</th>
                                <th scope="rowgroup" rowspan="2">Informations du compteur</th>
                                <th scope="row" colspan="1" class="metallicBlue">Abonnement*</th>
                                <th scope="row" colspan="3" class="metallicBlue">Terme de quantité (en €/MWh)</th>
                                <th scope="rowgroup" rowspan="2" class="metallicBlue">Budget énergie<br/>et acheminement<br/>(en €/an)</th>
                            </tr>
                            <tr>
                                <th scope="row" class="light-metallicBlue">€/mois</th>
